{
  "name": "@xgist/api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "TS backend template powered by tsup",
  "author": "William Nguyen",
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts, tsx, js,css,md}": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/prompt"
    }
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "dev": "npm run build && npm start",
    "db:seed": "tsx src/drizzle/seeds/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "build": "tsup",
    "start": "node --enable-source-maps dist/index.js",
    "watch": "tsup --watch",
    "watch:start": "tsup --watch --onSuccess \"npm start\"",
    "lint": "npx @biomejs/biome check src",
    "lint:fix": "npx @biomejs/biome check --apply src",
    "test": "vitest"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "sourcemap": true,
    "clean": true,
    "shims": true
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@bull-board/api": "^6.11.1",
    "@bull-board/fastify": "^6.11.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.0.2",
    "@fastify/swagger": "^9.5.1",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@scalar/fastify-api-reference": "^1.32.9",
    "@sinclair/typebox": "^0.34.38",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.10.0",
    "bullmq": "^5.56.4",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.3",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "form-data": "^4.0.4",
    "ioredis": "^5.6.1",
    "jsonata": "^2.0.6",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "lodash": "^4.17.21",
    "minio": "^8.0.5",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.34.3",
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  }
}
